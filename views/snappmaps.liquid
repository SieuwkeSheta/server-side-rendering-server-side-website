{% render 'partials/head.liquid',  title: 'Snappmaps', Snappmaps: true%}

{% for snappMapslist in snappMapslists %}
    {% comment %} Make variable for the date of 'today' {% endcomment %}
    {% assign today_date = 'now' | date: '%Y%m%d' %}

    {% for snappmap in snappMapslist.snappmap %}
        {% comment %} Make variable of the end-date of the 'snappmap' {% endcomment %}
        {% assign target_date = snappmap.snappthis_snapmap_uuid.time_end | date: '%Y%m%d'%}

        <ul>
            <li>{{ snappmap.snappthis_snapmap_uuid.name }}</li>

            {% comment %} If the end-date of the 'snapmap' has not yet ended before the date of 'today', add a text with 'Add your snapp!' {% endcomment %}
            {% if target_date > today_date %}
                <li><span>Add your snapp!</span></li>
            {% endif %}
        </ul>
    {% endfor %}
{% endfor %}

{% render 'partials/foot.liquid', SnappthisGroups: true %}